# =====================================================================
# ClinicalCopilot — environment variables
# Copy this file to .env and fill in the required values.
# =====================================================================

# ---------------------------------------------------------------
# REQUIRED — LLM provider key
# Which key you need depends on LLM_MODEL below.
# Default model uses Anthropic.
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here

# ---------------------------------------------------------------
# OPTIONAL — W&B / Weave tracing
# Without this, the server starts but all tracing is disabled.
# ---------------------------------------------------------------
WANDB_API_KEY=your_wandb_key_here
WANDB_ENABLED=set_true_or_false

# ---------------------------------------------------------------
# OPTIONAL — LLM model selection
# Swap providers without changing any agent code.
# Default: anthropic/claude-sonnet-4-20250514
# ---------------------------------------------------------------
# LLM_MODEL=anthropic/claude-sonnet-4-20250514
# LLM_MODEL=openai/gpt-4o
# LLM_MODEL=groq/llama-3.3-70b-versatile
# LLM_MODEL=ollama/llama3

# ---------------------------------------------------------------
# OPTIONAL — W&B project and entity
# WANDB_PROJECT controls the project name and trace URL.
# WANDB_ENTITY is your W&B username or org (used in weave_url).
# ---------------------------------------------------------------
WANDB_PROJECT=clinical-copilot
# WANDB_ENTITY=your_wandb_username

# ---------------------------------------------------------------
# OPTIONAL — API key authentication
# Set to enforce X-API-Key header on /upload, /normalize, /analyze.
# Leave unset to disable auth (suitable for local dev only).
# ---------------------------------------------------------------
# API_KEY=your_secret_key_here

# ---------------------------------------------------------------
# OPTIONAL — CORS allowed origins
# Comma-separated list. Default: http://localhost:5173 (Vite dev server).
# ---------------------------------------------------------------
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ---------------------------------------------------------------
# OPTIONAL — Frontend — set in ui/.env.local, not here
# Override the backend base URL for split-host deployments.
# Default: empty string (same-origin / Vite proxy).
# ---------------------------------------------------------------
# VITE_API_BASE_URL=http://localhost:8000